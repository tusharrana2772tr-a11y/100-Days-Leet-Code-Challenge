# Day - 9 Leet Code Problem No.707
# Design Linked List (Insertion at the Beginning of a Linked List)
class Node:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next

class MyLinkedList:
    def __init__(self):
        self.head = None
    def addAtHead(self, val: int) -> None:
        # 1. Create the new node
        new_node = Node(val)
        # 2. Point new node's next to the current head
        new_node.next = self.head
        # 3. Reassign head to be the new node
        self.head = new_node

# --- Define the traverse function ---
def traverse(head_node):
    curr = head_node
    while curr:
        print(curr.val, end=" -> ")
        curr = curr.next
    print("None")

a = Node(2) # creating nodes
b = Node(7)
c = Node(11)
d = Node(20)

a.next = b # linking nodes together
b.next = c
c.next = d

head = a 

# Insertion at the Beginning
new_node = Node(27)
new_node.next = head
head = new_node

print("Printing the Linked List")
traverse(head)
