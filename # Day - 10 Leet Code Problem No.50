# Power of a Number 
class Solution:
    def power(self, x, n):
        # Handle negative exponent
        if n < 0:
            x = 1 / x
            n = -n   
        result = 1.0
        current_product = x
        while n > 0:
            # If the lowest bit is 1, multiply the current power into the result
            if n % 2 == 1:
                result *= current_product
            # Square the base and shift n right (halve it)
            current_product *= current_product
            n //= 2
        return result

solution = Solution()
result = solution.power(2, 7)
print(result)
